[all:vars]
ansible_user=${username}
ansible_ssh_private_key_file=${private_key}
ansible_ssh_common_args=-o StrictHostKeyChecking=no -o ConnectTimeout=30
ansible_connection_timeout=30
ansible_python_interpreter=/usr/bin/python3

[marketing]
%{for vm in marketing_vm_instances ~}
${vm.name} ansible_host=${vm.external_ip} fqdn=${vm.fqdn}
%{endfor ~}

[analytics]
%{for vm in analytics_vm_instances ~}
${vm.name} ansible_host=${vm.external_ip} fqdn=${vm.fqdn}
%{endfor ~}
